@page
@model Portal.Pages.Admin.LoginModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>后台登录 — 金光集团</title>
    <link href="https://cdn.bootcdn.net/ajax/libs/twitter-bootstrap/5.3.8/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #f5f5f5; display: flex; align-items: center; justify-content: center; min-height: 100vh; font-family: system-ui, -apple-system, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif; }
        .login-box { background: #fff; padding: 40px; border-radius: 12px; box-shadow: 0 4px 24px rgba(0,0,0,0.1); width: 100%; max-width: 380px; }
        .login-box h2 { text-align: center; margin-bottom: 28px; color: #c41230; font-weight: 700; }
        .login-box .btn { width: 100%; padding: 10px; font-weight: 600; }
        .error { color: #dc3545; font-size: 14px; text-align: center; margin-bottom: 12px; }
        .hint { color: #999; font-size: 12px; text-align: center; margin-top: 16px; }
    </style>
</head>
<body>
<div class="login-box">
    <h2>后台管理</h2>
    @if (Model.Error != null)
    {
    <div class="error">@Model.Error</div>
    }
    <form method="post">
        <div class="mb-3">
            <label class="form-label">账号</label>
            <input type="text" name="Username" class="form-control" placeholder="请输入账号" required autofocus>
        </div>
        <div class="mb-3">
            <label class="form-label">密码</label>
            <input type="password" name="Password" class="form-control" placeholder="请输入密码" required>
        </div>
        <button type="submit" class="btn btn-danger">登 录</button>
    </form>
    <p class="hint">默认账号: admin / admin123</p>
</div>
</body>
</html>
