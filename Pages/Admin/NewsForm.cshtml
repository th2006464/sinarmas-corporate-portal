@page "{id:int?}"
@model Portal.Pages.Admin.NewsFormModel
@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="zh-CN">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>@(Model.IsEdit ? "编辑" : "发布")新闻 — 后台</title>
    <link href="https://cdn.bootcdn.net/ajax/libs/twitter-bootstrap/5.3.8/css/bootstrap.min.css" rel="stylesheet">
    <script src="js/tinymce/tinymce.min.js"></script>
    <style>
        body { font-family: system-ui, -apple-system, "Segoe UI", "PingFang SC", "Microsoft YaHei", sans-serif; background: #f8f9fa; }
        .header { background: #c41230; color: #fff; padding: 12px 24px; display: flex; justify-content: space-between; align-items: center; }
        .header h4 { margin: 0; }
        .header a { color: #fff; text-decoration: none; font-size: 14px; }
        .container { max-width: 900px; margin: 24px auto; padding: 0 16px; }
        .card { padding: 24px; border: none; border-radius: 12px; box-shadow: 0 2px 12px rgba(0,0,0,0.06); }
        .btn-submit { padding: 10px 32px; font-weight: 600; }
    </style>
</head>
<body>
<div class="header">
    <h4>@(Model.IsEdit ? "编辑新闻" : "发布新闻")</h4>
    <a href="admin/dashboard">← 返回列表</a>
</div>

<div class="container">
    <div class="card bg-white">
        @if (!ViewData.ModelState.IsValid)
        {
        <div class="alert alert-danger">
            @Html.ValidationSummary(false)
        </div>
        }

        <form method="post">
            <input type="hidden" name="IsEdit" value="@(Model.IsEdit ? "true" : "false")">
            @if (Model.IsEdit)
            {
            <input type="hidden" name="Id" value="@Model.Id">
            }

            <div class="mb-3">
                <label class="form-label fw-bold">标题 *</label>
                <input type="text" name="Title" class="form-control" value="@Model.Title" required placeholder="请输入新闻标题">
            </div>

            <div class="row mb-3">
                <div class="col-md-6">
                    <label class="form-label fw-bold">日期</label>
                    <input type="date" name="Date" class="form-control" value="@Model.Date">
                </div>
                <div class="col-md-6">
                    <label class="form-label fw-bold">视频链接（可选）</label>
                    <input type="text" name="VideoUrl" class="form-control" value="@Model.VideoUrl" placeholder="视频文件 URL，没有可留空">
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">摘要</label>
                <textarea name="Summary" class="form-control" rows="2" placeholder="简要描述（会显示在新闻列表中）">@Model.Summary</textarea>
            </div>

            <div class="mb-3">
                <label class="form-label fw-bold">内容 *</label>
                <textarea id="ContentEditor" name="NewsContent">@Model.NewsContent</textarea>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-danger btn-submit">
                    @(Model.IsEdit ? "保存修改" : "发布新闻")
                </button>
                <a href="admin/dashboard" class="btn btn-outline-secondary">取消</a>
            </div>
        </form>
    </div>
</div>

<script>
tinymce.init({
    selector: '#ContentEditor',
    height: 400,
    language: 'zh_CN',
    plugins: 'link image code table lists fullscreen',
    toolbar: 'undo redo | styles | bold italic underline | forecolor backcolor | alignleft aligncenter alignright | bullist numlist | link image | code fullscreen',
    menubar: false,
    branding: false,
    images_upload_handler: function (blobInfo, progress) {
        return new Promise(function (resolve, reject) {
            var reader = new FileReader();
            reader.onload = function (e) {
                resolve(e.target.result);
            };
            reader.onerror = reject;
            reader.readAsDataURL(blobInfo.blob());
        });
    }
});
</script>
</body>
</html>
